#!/bin/bash
# anchor_sync.sh - Refresh stale anchor thresholds in VictoriaMetrics
# Generated by Ansible - do not edit manually
#
# Logic: queries anchor series active in [14d] but not refreshed in [7d],
# then re-imports them with the current timestamp to prevent expiry.

VM_QUERY_URL="{{ vm_query_url }}"
VM_IMPORT_URL="{{ vm_import_url }}"
BATCH_SIZE=500
BATCH_SLEEP="0.05"   # seconds between batches (50ms)
ANCHOR_TYPES=("cpu" "mem" "bw_in" "bw_out")
SD_CONFIG="/opt/vmagent/sd_configs/libvirt_nodes.json"

log_info()  { echo "[INFO]  $(date '+%Y-%m-%d %H:%M:%S') $*"; }
log_error() { echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') $*" >&2; }

# Verify dependencies
for cmd in curl jq; do
    if ! command -v "$cmd" &>/dev/null; then
        log_error "Required command not found: $cmd"
        exit 1
    fi
done

# Detect local region from libvirt service discovery config
# Extracts prefix before first '-' from hypervisor label
# e.g. hypervisor="sv6-cland-compute-3" -> region="sv6"
REGION=""
if [ -f "$SD_CONFIG" ]; then
    HYPERVISOR=$(jq -r '.[0].labels.hypervisor // empty' "$SD_CONFIG" 2>/dev/null)
    if [ -n "$HYPERVISOR" ]; then
        REGION="${HYPERVISOR%%-*}"
    fi
fi

if [ -z "$REGION" ]; then
    log_error "Failed to detect region from ${SD_CONFIG}. Cannot proceed without region filter."
    exit 1
fi

log_info "Detected local region: ${REGION}"

TOTAL_REFRESHED=0
TOTAL_ERRORS=0

for TYPE in "${ANCHOR_TYPES[@]}"; do
    METRIC_NAME="vm_${TYPE}_anchor"
    log_info "Processing anchor type: ${TYPE} (metric: ${METRIC_NAME})"

    # Query stale anchors for this region only: active in [14d] but NOT updated in [7d]
    QUERY="last_over_time(${METRIC_NAME}{region=\"${REGION}\"}[14d]) > 0 unless last_over_time(${METRIC_NAME}{region=\"${REGION}\"}[7d]) > 0"

    RESPONSE=$(curl -sf --max-time 30 \
        "${VM_QUERY_URL}/api/v1/query" \
        --data-urlencode "query=${QUERY}" 2>&1)
    CURL_RC=$?

    if [ $CURL_RC -ne 0 ]; then
        log_error "Query failed for ${TYPE} (curl exit=${CURL_RC}): ${RESPONSE}"
        TOTAL_ERRORS=$((TOTAL_ERRORS + 1))
        continue
    fi

    STATUS=$(echo "$RESPONSE" | jq -r '.status' 2>/dev/null)
    if [ "$STATUS" != "success" ]; then
        log_error "Query returned non-success for ${TYPE}: $(echo "$RESPONSE" | jq -c '.error // .message // .' 2>/dev/null)"
        TOTAL_ERRORS=$((TOTAL_ERRORS + 1))
        continue
    fi

    COUNT=$(echo "$RESPONSE" | jq '.data.result | length' 2>/dev/null)
    if [ -z "$COUNT" ] || [ "$COUNT" -eq 0 ]; then
        log_info "No stale anchors for ${TYPE}, skipping."
        continue
    fi

    log_info "Found ${COUNT} stale ${TYPE} anchor(s) to refresh."

    # Build prometheus text format lines with current timestamp
    NOW_MS=$(date +%s%3N)
    LINES=$(echo "$RESPONSE" | jq -r \
        --arg m "$METRIC_NAME" \
        --arg ts "$NOW_MS" \
        '.data.result[] |
         (.metric | del(.__name__) | to_entries | map("\(.key)=\"\(.value)\"") | join(",")) as $labels |
         "\($m){\($labels)} \(.value[1]) \($ts)"' 2>/dev/null)

    if [ -z "$LINES" ]; then
        log_error "Failed to build prometheus lines for ${TYPE}"
        TOTAL_ERRORS=$((TOTAL_ERRORS + 1))
        continue
    fi

    # Batch import
    BATCH_NUM=0
    REFRESHED=0
    BATCH_LINES=""
    BATCH_COUNT=0

    while IFS= read -r LINE; do
        [ -z "$LINE" ] && continue
        BATCH_LINES="${BATCH_LINES}${LINE}"$'\n'
        BATCH_COUNT=$((BATCH_COUNT + 1))

        if [ "$BATCH_COUNT" -ge "$BATCH_SIZE" ]; then
            BATCH_NUM=$((BATCH_NUM + 1))
            IMPORT_RESP=$(printf '%s' "$BATCH_LINES" | curl -sf --max-time 60 \
                -X POST \
                -H "Content-Type: text/plain" \
                --data-binary @- \
                "${VM_IMPORT_URL}/api/v1/import/prometheus" 2>&1)
            if [ $? -ne 0 ]; then
                log_error "Import batch ${BATCH_NUM} failed for ${TYPE}: ${IMPORT_RESP}"
                TOTAL_ERRORS=$((TOTAL_ERRORS + 1))
            else
                REFRESHED=$((REFRESHED + BATCH_COUNT))
                log_info "Batch ${BATCH_NUM}: imported ${BATCH_COUNT} lines for ${TYPE}"
            fi
            BATCH_LINES=""
            BATCH_COUNT=0
            sleep "$BATCH_SLEEP"
        fi
    done <<< "$LINES"

    # Flush remaining lines
    if [ "$BATCH_COUNT" -gt 0 ]; then
        BATCH_NUM=$((BATCH_NUM + 1))
        IMPORT_RESP=$(printf '%s' "$BATCH_LINES" | curl -sf --max-time 60 \
            -X POST \
            -H "Content-Type: text/plain" \
            --data-binary @- \
            "${VM_IMPORT_URL}/api/v1/import/prometheus" 2>&1)
        if [ $? -ne 0 ]; then
            log_error "Import final batch ${BATCH_NUM} failed for ${TYPE}: ${IMPORT_RESP}"
            TOTAL_ERRORS=$((TOTAL_ERRORS + 1))
        else
            REFRESHED=$((REFRESHED + BATCH_COUNT))
            log_info "Batch ${BATCH_NUM} (final): imported ${BATCH_COUNT} lines for ${TYPE}"
        fi
    fi

    log_info "Completed ${TYPE}: refreshed ${REFRESHED}/${COUNT} in ${BATCH_NUM} batch(es)."
    TOTAL_REFRESHED=$((TOTAL_REFRESHED + REFRESHED))
done

log_info "Anchor sync complete. total_refreshed=${TOTAL_REFRESHED} errors=${TOTAL_ERRORS}"

if [ "$TOTAL_ERRORS" -gt 0 ]; then
    exit 1
fi
exit 0
