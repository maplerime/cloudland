groups:
- name: ipgroup-available-ip-monitor
  rules:
    # Recording rule: per-ipgroup threshold lookup table.
    # Each entry is label_replace(vector(<threshold>), "ipgroup_name", "<name>", "", "").
    # Only ipgroups listed here will be matched by the alert rule below.
    - record: cloudland_ipgroup_threshold
      expr: |
{{ threshold_expr }}

    # Single alert rule: joins available-IP totals against the threshold lookup table.
    # ipgroup_name is carried via group_left and appears automatically in alert labels.
    - alert: IPGroupLowAvailableIPs
      expr: |
        sum by (ipgroup_id, region, ipgroup_name) (
          max by (ipgroup_id, subnet_id, region) (
            cloudland_subnet_ip_available
          )
        )
        * on (ipgroup_id, region)
          group_left(ipgroup_name)
          max by (ipgroup_id, region, ipgroup_name) (cloudland_ipgroup_info{type="system"})
        < on(ipgroup_name) group_left() cloudland_ipgroup_threshold
      for: {{ for_duration | default("5m") }}
      labels:
        severity: {{ severity | default("warning") }}
        component: network
        alert_type: ipgroup_low_ips
      annotations:
        summary: "IP Group {{ $labels.ipgroup_name }} total available IPs low"
        description: |
          IP Group: {{ $labels.ipgroup_name }} ({{ $labels.ipgroup_id }}) available IPs are {{ $value }} in region {{ $labels.region }}, lower than {{ with query (printf "cloudland_ipgroup_threshold{ipgroup_name=\"%s\"}" $labels.ipgroup_name) }}{{ printf "%.0f" (. | first | value) }}{{ end }}
