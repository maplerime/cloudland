groups:
- name: node-conntrack-anomaly
  rules:
    # Rule 1: High unreplied SYN connections detected from source IP
    - alert: HighUnrepliedSynFromSourceIP
      expr: sum by (source_ip, hostname, region) (conntrack_unreplied_syn_flows) > {{ source_threshold | default(150) }}
      for: {{ source_duration | default("2m") }}
      labels:
        severity: {{ source_severity | default("warning") }}
        component: network
        alert_type: unreplied_syn_source
        hostname: "{{ '{{' }} $labels.hostname {{ '}}' }}"
        region: "{{ '{{' }} $labels.region {{ '}}' }}"
      annotations:
        summary: "High unreplied SYN connections from source IP {{ '{{' }} $labels.source_ip {{ '}}' }} on {{ '{{' }} $labels.hostname {{ '}}' }}"
        description: |
          Source IP: {{ '{{' }} $labels.source_ip {{ '}}' }}
          Total unreplied SYN connections: {{ '{{' }} $value {{ '}}' }}
          Compute node: {{ '{{' }} $labels.hostname {{ '}}' }}
          Region: {{ '{{' }} $labels.region {{ '}}' }}
          Query: conntrack_unreplied_syn_flows{source_ip="{{ '{{' }} $labels.source_ip {{ '}}' }}", hostname="{{ '{{' }} $labels.hostname {{ '}}' }}"}
    
    # Rule 2: High unreplied SYN connections detected to target IP
    - alert: HighUnrepliedSynToTargetIP
      expr: sum by (target_ip, hostname, region) (conntrack_unreplied_syn_flows) > {{ target_threshold | default(150) }}
      for: {{ target_duration | default("2m") }}
      labels:
        severity: {{ target_severity | default("warning") }}
        component: network
        alert_type: unreplied_syn_target
        hostname: "{{ '{{' }} $labels.hostname {{ '}}' }}"
        region: "{{ '{{' }} $labels.region {{ '}}' }}"
      annotations:
        summary: "High unreplied SYN connections to target IP {{ '{{' }} $labels.target_ip {{ '}}' }} on {{ '{{' }} $labels.hostname {{ '}}' }}"
        description: |
          Target IP: {{ '{{' }} $labels.target_ip {{ '}}' }}
          Total unreplied SYN connections: {{ '{{' }} $value {{ '}}' }}
          Compute node: {{ '{{' }} $labels.hostname {{ '}}' }}
          Region: {{ '{{' }} $labels.region {{ '}}' }}
          Query: conntrack_unreplied_syn_flows{target_ip="{{ '{{' }} $labels.target_ip {{ '}}' }}", hostname="{{ '{{' }} $labels.hostname {{ '}}' }}"}
