groups:
- name: bw_out_{{ owner }}_{{ rule_group }}
  rules:
  - alert: HighBWOutUsage_{{ owner }}_{{ rule_group }}
    expr: |
      (
        sum by (domain) (rate(libvirt_domain_interface_stats_transmit_bytes_total[1m])) > {{ out_threshold }}
      ) or ignoring(rule_id)
      up{job="vm-group-metadata", rule_id=~"bw-.*-{{ rule_group }}"}
    for: {{ out_duration }}s
    labels:
      severity: '{{ if $labels.rule_id }}critical{{ else }}warning{{ end }}'
      matched: '{{ if $labels.rule_id }}true{{ else }}false{{ end }}'
      rule_group: "{{ rule_group }}"
      alert_type: bw
      owner: "{{ owner }}"
      email: "{{ email | default('') }}"
      action: "{{ action | default('false') }}"
      target_device: "{{ target_device | default('') }}"
    annotations:
      summary: "High Network Out Usage ({{ $value }})"
      description: "VM {{ $labels.domain }} has high network out usage or is matched for {{ out_duration }} seconds"

  - alert: BWOutUsageRecovered_{{ owner }}_{{ rule_group }}
    expr: |
      (
        sum by (domain) (rate(libvirt_domain_interface_stats_transmit_bytes_total[1m])) < {{ out_down_to }}
      ) and ignoring(rule_id)
      up{job="vm-group-metadata", rule_id=~"bw-.*-{{ rule_group }}"}
    for: {{ out_down_duration }}s
    labels:
      severity: '{{ if $labels.rule_id }}info{{ else }}info{{ end }}'
      matched: '{{ if $labels.rule_id }}true{{ else }}false{{ end }}'
      rule_group: "{{ rule_group }}"
      alert_type: bw
      owner: "{{ owner }}"
      email: "{{ email | default('') }}"
      action: "{{ action | default('false') }}"
      target_device: "{{ target_device | default('') }}"
    annotations:
      summary: "Network Out Usage Recovered ({{ $value }})"
      description: "VM {{ $labels.domain }} network out usage has dropped below threshold for {{ out_down_duration }} seconds" 