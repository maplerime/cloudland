[
{% set comma = joiner(",") %}
{% for host in groups['cland'] | default([]) %}
  {{ comma() }}
  {
    "targets": ["{{ hostvars[host]['ansible_host'] | default(hostvars[host]['ansible_ssh_host']) | default(host) }}:9102"],
    "labels": {
      "host": "{{ host }}",
      "node_type": "management",
      "exporter_type": "cloudland"
    }
  }
{% endfor %}
]
