{{template "_head" .}}
<div class="user signup">
	<div class="ui middle very relaxed page grid">
        <div class="column" >
            <form class="ui form" action="{{.Link}}" method="post">
                <h3 class="ui top attached header">
                    {{.i18n.Tr "Update Volume"}}
                </h3>
                <div class="ui attached segment">
                    <div class="required inline field">
                        <label for="name">{{.i18n.Tr "Name"}}</label>
                        <input id="name" name="name" value="{{ .Volume.Name }}" required>
                    </div>
                    <div class="inline field">
                        <label for="createdat">{{.i18n.Tr "Created_At"}}</label>
                        <input id="createdat" name="createdat" value="{{ .Volume.CreatedAt }}" disabled>
                    </div>
                    <div class="inline field">
                        <label for="updatedat">{{.i18n.Tr "Updated_At"}}</label>
                        <input id="updatedat" name="updatedat" value="{{ .Volume.UpdatedAt }}" disabled>
                    </div>
                    <div class="inline field">
                        <label for="size">{{.i18n.Tr "Size"}} (G)</label>
                        <input id="size"  name="size" value="{{ .Volume.Size }}" disabled>
                    </div>
                    <div class="inline field">
                        <label for="instance">{{.i18n.Tr "Attached to Instance"}}</label>
                        <div class="ui mini icon input" style="margin-bottom:5px;max-width:300px">
                            <input type="text" id="instanceSearch" placeholder="{{.i18n.Tr "Search"}} ID / Name..." autocomplete="off" onkeydown="if(event.key==='Enter'){event.preventDefault();$(this).trigger('input');}">
                            <i class="search icon link" onclick="$('#instanceSearch').trigger('input')"></i>
                        </div>
						<div class="ui selection dropdown" id="instanceDropdown">
						  <input id="instance" name="instance" type="hidden">
						  <i class="dropdown icon"></i>
						  {{ if .Volume.Instance }}
						  <div data-value={{.Volume.Instance.ID}} class="default text">{{.Volume.Instance.ID}}-{{.Volume.Instance.Hostname}}</div>
						  {{ else }}
						  <div data-value=0 class="default text">{{.i18n.Tr "Not Attached at All"}}</div>
						  {{ end }}
						  <div class="menu" id="instanceMenu">
							<div class="item" data-value=0 data-text="Not Attached at All">{{.i18n.Tr "Not Attached at All"}}</div>
                            {{ if .Volume.Instance }}
							<div class="item" data-value={{.Volume.Instance.ID}} data-text="{{.Volume.Instance.ID}}-{{.Volume.Instance.Hostname}}">
							  {{.Volume.Instance.ID}}-{{.Volume.Instance.Hostname}}
							</div>
                            {{ end }}
						  </div>
						</div>
                    </div>
                    <div class="inline field">
                        <label></label>
                        <button class="ui green button">{{.i18n.Tr "Update Volume"}}</button>
                    </div>
                </div>
            </form>
        </div>
	</div>
</div>
<script>
(function(){
    var timer;
    $('#instanceSearch').on('input', function(){
        var q = $(this).val();
        clearTimeout(timer);
        timer = setTimeout(function(){
            $.getJSON('/instances/search.json', {q: q}, function(data){
                var menu = document.getElementById('instanceMenu');
                var currentVal = $('#instanceDropdown').dropdown('get value');
                var html = '<div class="item" data-value="0">Not Attached at All</div>';
                if (data.results) {
                    for (var i = 0; i < data.results.length; i++) {
                        var r = data.results[i];
                        html += '<div class="item" data-value="' + r.value + '">' + r.name + '</div>';
                    }
                }
                menu.innerHTML = html;
                $('#instanceDropdown').dropdown('refresh');
                if (currentVal) $('#instanceDropdown').dropdown('set selected', currentVal);
            });
        }, 300);
    });
})();
</script>
{{template "_footer" .}}

