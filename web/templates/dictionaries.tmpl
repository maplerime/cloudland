{{template "_head" .}}
<div class="admin user">
    <div class="ui container">
        <div class="ui grid">
            {{template "_left" .}}
            <div class="twelve wide column content">
                <h4 class="ui top attached header">
                    {{.i18n.Tr "Dictionary_Manage_Panel"}} ({{.i18n.Tr "Total"}}: {{.Total}})
                    <div class="ui right">
                        {{template "_column_selector" .}}
                        <a class="ui green tiny button" href="dictionaries/new">{{.i18n.Tr "Create"}}</a>
                    </div>
                </h4>
                <div class="ui attached segment">
                    <form class="ui form">
                        <div class="ui fluid tiny action input">
                            <input name="q" value="{{ .Query }}" placeholder="Search..." autofocus>
                            <button class="ui blue tiny button">{{.i18n.Tr "Search"}}</button>
                        </div>
                    </form>
                </div>
                <div class="ui unstackable attached table segment">
                    <table class="ui unstackable very basic striped table">
                        <thead>
                            <tr>
                                <th data-column="ID">{{.i18n.Tr "ID"}}</th>
                                <th data-column="UUID">{{.i18n.Tr "UUID"}}</th>
                                <th data-column="Category">{{.i18n.Tr "Category"}}</th>
                                <th data-column="Name">{{.i18n.Tr "Name"}}</th>
                                <th data-column="Value">{{.i18n.Tr "Value"}}</th>
                                <th data-column="ShortName">{{.i18n.Tr "ShortName"}}</th>
                                <th data-column="SubType1">{{.i18n.Tr "SubType1"}}</th>
                                <th data-column="SubType2">{{.i18n.Tr "SubType2"}}</th>
                                <th data-column="SubType3">{{.i18n.Tr "SubType3"}}</th>
                                <th data-column="Edit">{{.i18n.Tr "Edit"}}</th>
                                <th data-column="Delete">{{.i18n.Tr "Delete"}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{ $Link := .Link }}
                            {{ range .Dictionaries }}
                            <tr>
                                <td data-column="ID">{{.ID}}</td>
                                <td data-column="UUID">{{.UUID}}</td>
                                <td data-column="Category">{{.Category}}</td>
                                <td data-column="Name">{{.Name}}</td>
                                <td data-column="Value">{{.Value}}</td>
                                <td data-column="ShortName">{{.ShortName}}</td>
                                <td data-column="SubType1">{{.SubType1}}</td>
                                <td data-column="SubType2">{{.SubType2}}</td>
                                <td data-column="SubType3">{{.SubType3}}</td>
                                <td data-column="Edit"><a href="{{$Link}}/{{.ID}}"><i class="fa fa-pencil-square-o"></i></a></td>
                                <td data-column="Delete"><div class="delete-button" data-url="{{$Link}}/{{.ID}}" data-id="{{.ID}}"><i class="dark purple trash alternate outline icon"></i></div></td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                </div>
                {{template "_pagination" .}}
            </div>
        </div>
    </div>
</div>
<div class="ui small basic delete modal">
    <div class="ui icon header">
        <i class="trash icon"></i>
        {{.i18n.Tr "Dictionary Deletion"}}
    </div>
    <div class="content">
        <p>{{.i18n.Tr "Dictionary_Deletion_Confirm"}}</p>
    </div>
    {{template "_delete_modal_actions" .}}
</div>
{{template "_footer" .}}