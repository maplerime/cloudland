{{template "_head" .}}
<div class="admin user">

    <div class="ui container">

        <div class="ui grid">

        {{template "_left" .}}
			<div class="user signup">
				<div class="ui middle very relaxed page grid">
					<div class="" >
						<form class="ui form" action="{{.Link}}" method="post">
							<h3 class="ui top attached header">
								{{.i18n.Tr "Create New Image"}}
							</h3>
							<div class="ui attached segment">
								<div class="required inline field">
									<label for="osCode">{{.i18n.Tr "OSCode"}}</label>
									<select name="osCode" id="osCode" class="ui selection dropdown">
										 <option value="linux" selected>Linux</option>
										 <option value="windows">Windows</option>
										 <option value="other">Others</option>
									</select>
								</div>
								<div class="required inline field">
									<label for="name">{{.i18n.Tr "Name"}}</label>
									<input id="name" name="name" autofocus required>
								</div>
								<div class="inline field">
									<label for="uuid">{{.i18n.Tr "UUID"}}</label>
									<input id="uuid" name="uuid" autocomplete="off">
								</div>
								<div class="inline field">
									<label for="instance">{{.i18n.Tr "From Instance"}}</label>
									<div class="ui mini icon input" style="margin-bottom:5px;width:100%">
										<input type="text" id="instanceSearch" placeholder="{{.i18n.Tr "Search"}} ID / Name..." autocomplete="off">
										<i class="search icon"></i>
									</div>
									<select name="instance" id="instance" class="ui selection dropdown">
										 <option value="0" selected>{{.i18n.Tr "None"}}</option>
									</select>
								</div>
								<div class="inline field">
									<label for="url">{{.i18n.Tr "Download Url"}}</label>
									<input id="url" name="url" autocomplete="off">
								</div>
								<div class="required inline field">
									<label for="architecture">{{.i18n.Tr "Architecture"}}</label>
									<select name="architecture" id="architecture" class="ui selection dropdown">
                                         <option value="0" selected>x86_64</option>
                                         <option value="1">s390x</option>
                                    </select>
								</div>
								<div class="required inline field">
									<label for="bootLoader">{{.i18n.Tr "Boot Loader"}}</label>
									<select name="bootLoader" id="bootLoader" class="ui selection dropdown">
                                         <option value="bios" selected>bios</option>
                                         <option value="uefi">uefi</option>
                                    </select>
								</div>
								<div class="required inline field">
									<label for="isRescue">{{.i18n.Tr "Is Rescue Image"}}</label>
									<select name="isRescue" id="isRescue" class="ui selection dropdown">
                                         <option value="false" selected>false</option>
                                         <option value="true">true</option>
                                    </select>
								</div>
                                <div class="inline field">
                                    <label for="image">{{.i18n.Tr "Rescue Image"}}</label>
                                    <div class="ui selection dropdown">
                                      <input id="rescueImage" name="rescueImage" type="hidden" required>
                                      <i class="dropdown icon"></i>
                                      <div class="default text">{{.i18n.Tr "Rescue Image"}}</div>
                                      <div class="menu">
                                        {{ range .RescueImages }}
                                               <div class="item" data-value={{.ID}} data-text={{.Name}}>
                                               {{.Name}}
                                               </div>
                                        {{ end }}
                                      </div>
                                    </div>
                                </div>
							<div class="required inline field">
								<label for="osFamily">{{.i18n.Tr "OS Family"}}</label>
								<select name="osFamily" id="osFamily" class="ui selection dropdown">
									{{ range .OsFamilies }}
										<option value="{{ .Value }}">{{ .Name }}</option>
									{{ end }}
								</select>
							</div>
							<div class="required inline field">
                                    <label for="osVersion">{{.i18n.Tr "OS Version"}}</label>
                                    <input id="osVersion" name="osVersion" autocomplete="off">
                                </div>
                                <div class="required inline field">
                                    <label for="userName">{{.i18n.Tr "Default Username"}}</label>
                                    <input id="userName" name="userName" autocomplete="off">
                                </div>
								<div class="inline field">
									<label></label>
									<button class="ui green button">{{.i18n.Tr "Create New Image"}}</button>
								</div>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<script>
(function(){
    var timer;
    $('#instanceSearch').on('input', function(){
        var q = $(this).val();
        clearTimeout(timer);
        timer = setTimeout(function(){
            $.getJSON('/instances/search.json', {q: q}, function(data){
                var sel = document.getElementById('instance');
                var currentVal = sel.value;
                var html = '<option value="0">None</option>';
                if (data.results) {
                    for (var i = 0; i < data.results.length; i++) {
                        var r = data.results[i];
                        html += '<option value="' + r.value + '"' +
                                (String(r.value) === currentVal ? ' selected' : '') +
                                '>' + r.name + '</option>';
                    }
                }
                sel.innerHTML = html;
                $(sel).dropdown('refresh');
            });
        }, 300);
    });
})();
</script>
{{template "_footer" .}}


