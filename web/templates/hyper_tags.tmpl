{{template "_head" .}}
    <div class="admin user">
        <div class="ui container">
            <div class="ui grid">
                {{template "_left" .}}
                <div class="twelve wide column content">
                    <h4 class="ui top attached header">
                        {{.i18n.Tr "Hyper"}} {{.Hyper.Hostname}} (ID: {{.Hostid}}) — Tags
                        <div class="ui right">
                            <a class="ui tiny button" href="/hypers">{{.i18n.Tr "Back"}}</a>
                        </div>
                    </h4>

                    <div class="ui attached segment">
                        <form class="ui form" action="/hypers/{{.Hostid}}/tags/new" method="post">
                            <div class="three fields">
                                <div class="field">
                                    <label>Tag Name</label>
                                    <input name="tag_name" placeholder="e.g. gpu, nvme, nested" required>
                                </div>
                                <div class="field">
                                    <label>Tag Value</label>
                                    <input name="tag_value" placeholder="e.g. nvidia-a100, true">
                                </div>
                                <div class="field">
                                    <label>&nbsp;</label>
                                    <button class="ui green button" type="submit">{{.i18n.Tr "Add"}}</button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="ui unstackable attached table segment">
                        <table class="ui unstackable very basic striped table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tag Name</th>
                                    <th>Tag Value</th>
                                    <th>{{.i18n.Tr "Action"}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{ range .Tags }}
                                <tr>
                                    <td>{{.ID}}</td>
                                    <td>{{.TagName}}</td>
                                    <td>{{.TagValue}}</td>
                                    <td>
                                        <div class="delete-button" data-url="/hypers/{{$.Hostid}}/tags/{{.ID}}" data-id="{{.ID}}">
                                            <i class="dark purple trash alternate outline icon"></i>
                                        </div>
                                    </td>
                                </tr>
                                {{ end }}
                                {{ if not .Tags }}
                                <tr>
                                    <td colspan="4" style="text-align:center;">No tags configured</td>
                                </tr>
                                {{ end }}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
<div class="ui small basic delete modal">
    <div class="ui icon header">
        <i class="trash icon"></i>
        Delete Tag
    </div>
    <div class="content">
        <p>Are you sure you want to delete this tag?</p>
    </div>
    {{template "_delete_modal_actions" .}}
</div>
{{template "_footer" .}}
