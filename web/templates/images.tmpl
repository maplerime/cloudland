{{template "_head" .}}
    <div class="admin user">
	    <div class="ui container">
		    <div class="ui grid">
                {{template "_left" .}}
          	    <div class="twelve wide column content">
		            <h4 class="ui top attached header">
			            {{.i18n.Tr "Image_Manage_Panel"}} ({{.i18n.Tr "Total"}}: {{.Total}})
			            <div class="ui right">
				            {{template "_column_selector" .}}
				            <a class="ui green tiny button" href="images/new">{{.i18n.Tr "Create"}}</a>
			            </div>
		            </h4>
		            <div class="ui attached segment">
			            <form class="ui form">
	                        <div class="ui fluid tiny action input">
	                            <select name="search_field" id="searchField" data-current="{{.SearchField}}" onchange="toggleSearch()" style="min-width:120px;max-width:160px;border-right:0;border-radius:.28571429rem 0 0 .28571429rem;">
	                                <option value="name">{{.i18n.Tr "Name"}}</option>
	                                <option value="id">ID</option>
	                                <option value="uuid">UUID</option>
	                                <option value="os_code">{{.i18n.Tr "OSCode"}}</option>
	                                <option value="status">{{.i18n.Tr "Status"}}</option>
	                            </select>
	                            <input name="q" id="searchInput" value="{{ .Query }}" placeholder="{{.i18n.Tr "Search"}}..." autofocus>
	                            <select name="q" id="searchSelect" style="display:none" disabled></select>
	                            <button class="ui blue tiny button">{{.i18n.Tr "Search"}}</button>
	                        </div>
                        </form>
                        <script>
                        (function(){
                            var enums = {
                                os_code: [['','-- All --'],['linux','Linux'],['windows','Windows'],['other','Other']],
                                status: [['','-- All --'],['available','available'],['creating','creating'],['error','error']]
                            };
                            var fieldEl = document.getElementById('searchField');
                            var inputEl = document.getElementById('searchInput');
                            var selectEl = document.getElementById('searchSelect');
                            var savedField = fieldEl.getAttribute('data-current');
                            var savedQuery = inputEl.value;
                            window.toggleSearch = function() {
                                var f = fieldEl.value, opts = enums[f];
                                if (opts) {
                                    inputEl.style.display = 'none'; inputEl.disabled = true;
                                    selectEl.style.display = ''; selectEl.disabled = false;
                                    selectEl.innerHTML = '';
                                    for (var i = 0; i < opts.length; i++) {
                                        var o = document.createElement('option');
                                        o.value = opts[i][0]; o.textContent = opts[i][1];
                                        if (f === savedField && opts[i][0] === savedQuery) o.selected = true;
                                        selectEl.appendChild(o);
                                    }
                                } else {
                                    inputEl.style.display = ''; inputEl.disabled = false;
                                    selectEl.style.display = 'none'; selectEl.disabled = true;
                                }
                            };
                            for (var i = 0; i < fieldEl.options.length; i++) {
                                if (fieldEl.options[i].value === savedField) { fieldEl.selectedIndex = i; break; }
                            }
                            toggleSearch();
                        })();
                        </script>
		            </div>
		            <div class="ui unstackable attached table segment">
                        <table class="ui unstackable very basic striped table">
	                        <thead>
		                        <tr>
									{{ if $.IsAdmin }}
			                        <th data-column="ID">{{.i18n.Tr "ID"}}</th>
									{{ end }}
									<th data-column="UUID">{{.i18n.Tr "UUID"}}</th>
			                        <th data-column="Name">{{.i18n.Tr "Name"}}</th>
			                        <th data-column="Format">{{.i18n.Tr "Format"}}</th>
			                        <th data-column="Status">{{.i18n.Tr "Status"}}</th>
			                        <th data-column="CreatedAt">{{.i18n.Tr "Created_At"}}</th>
			                        <th data-column="OSCode">{{.i18n.Tr "OSCode"}}</th>
									<th data-column="OSFamily">{{.i18n.Tr "OS Family"}}</th>
			                        <th data-column="OSVersion">{{.i18n.Tr "OS Version"}}</th>
			                        <th data-column="Size">{{.i18n.Tr "Size"}}</th>
			                        <th data-column="DefaultUsername">{{.i18n.Tr "Default Username"}}</th>
			                        <th data-column="Architecture">{{.i18n.Tr "Architecture"}}</th>
			                        <th data-column="BootLoader">{{.i18n.Tr "Boot Loader"}}</th>
                                    <th data-column="Action">{{.i18n.Tr "Action"}}</th>
		                        </tr>
	                        </thead>
	                        <tbody>
                                {{ $Link := .Link }}
                                {{ range .Images }}
		                        <tr>
									{{ if $.IsAdmin }}
									<td data-column="ID"><a href="{{$Link}}/{{.ID}}">{{.ID}}</a></td>
									{{ end }}
									<td data-column="UUID"><a href="{{$Link}}/{{.ID}}">{{.UUID}}</a></td>
			                        <td data-column="Name">{{.Name}}</td>
			                        <td data-column="Format">{{.Format}}</td>
			                        <td data-column="Status">{{.Status}}</td>
			                        <td data-column="CreatedAt"><span title="{{.CreatedAt}}">{{.CreatedAt}}</span></td>
			                        <td data-column="OSCode">{{.OSCode}}</td>
									<td data-column="OSFamily">{{.OsFamily}}</td>
			                        <td data-column="OSVersion">{{.OsVersion}}</td>
                                    <td data-column="Size">{{.Size}}</td>
			                        <td data-column="DefaultUsername">{{.UserName}}</td>
			                        <td data-column="Architecture">{{.Architecture}}</td>
			                        <td data-column="BootLoader">{{.BootLoader}}</td>
                                    <td data-column="Action">
                                        <div class="ui selection dropdown">
                                            <input id="action" name="action" type="hidden">
                                                <i class="dropdown icon"></i>
                                                <div class="default text">Action</div>
                                                <div class="menu">
                                                    <div class="item" data-text="StoragePool">
                                                        <a href="/images/{{.ID}}/storages">{{$.i18n.Tr "StoragePool"}}</a>
                                                    </div>
                                                    <div class="item" data-text="DeleteImage">
                                                        <a class="delete-button" data-url="{{$Link}}/{{.ID}}" data-id="{{.ID}}" href="javascript:void(0)">{{$.i18n.Tr "Delete"}}</a>
                                                    </div>
                                                </div>
                                        </div>
                                    </td>
		                        </tr>
                                {{ end }}
	                        </tbody>
                        </table>
		            </div>
		            {{template "_pagination" .}}
	            </div>
            </div>
        </div>
    </div>
    <div class="ui small basic delete modal">
	    <div class="ui icon header">
		    <i class="trash icon"></i>
            {{.i18n.Tr "Image Deletion"}}
	    </div>
	    <div class="content">
		    <p>{{.i18n.Tr "Image_Deletion_Confirm"}}</p>
	    </div>
	    {{template "_delete_modal_actions" .}}
    </div>

{{template "_footer" .}}
