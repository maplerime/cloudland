{{if .ListName}}
<div class="column-selector-wrapper">
	<button class="ui tiny button" id="columnSelectorButton" data-default="{{.DefaultColumnsJSON}}" data-listname="{{.ListName}}" type="button">
		<i class="columns icon"></i> {{.i18n.Tr "Columns"}}
	</button>
	<div class="column-selector-panel" id="columnSelectorPanel">
		{{if .AvailableColumns}}
			<div class="column-selector-list">
				{{range .AvailableColumns}}
					<label class="column-selector-item">
						<input type="checkbox" class="column-checkbox" data-column="{{.}}" value="{{.}}">
						<span>{{.}}</span>
					</label>
				{{end}}
			</div>
			<div class="column-selector-actions">
				<button class="ui tiny primary button" type="button" onclick="saveColumnPreference('{{.ListName}}')">{{.i18n.Tr "Apply"}}</button>
				<button class="ui tiny button" type="button" onclick="resetColumns('{{.ListName}}')">{{.i18n.Tr "Reset"}}</button>
			</div>
		{{end}}
	</div>
</div>

<script>
(function() {
	'use strict';

	function getStorageKey(listName) {
		return 'columns_' + listName;
	}

	// Toggle dropdown panel
	var btn = document.getElementById('columnSelectorButton');
	var panel = document.getElementById('columnSelectorPanel');
	if (btn && panel) {
		btn.addEventListener('click', function(e) {
			e.stopPropagation();
			panel.classList.toggle('visible');
		});
		// Clicking inside panel should NOT close it
		panel.addEventListener('click', function(e) {
			e.stopPropagation();
		});
		// Clicking outside closes the panel
		document.addEventListener('click', function() {
			panel.classList.remove('visible');
		});
	}

	function closePanel() {
		if (panel) panel.classList.remove('visible');
	}

	// Initialize column visibility from localStorage
	window.initColumnSelector = function(listName, defaultColumnsJSON) {
		var storageKey = getStorageKey(listName);
		var savedColumns = localStorage.getItem(storageKey);
		var visibleColumns;
		var defaultColumns = [];

		if (defaultColumnsJSON) {
			try { defaultColumns = JSON.parse(defaultColumnsJSON); } catch(e) { defaultColumns = []; }
		}

		if (savedColumns) {
			try { visibleColumns = JSON.parse(savedColumns); } catch(e) { visibleColumns = defaultColumns; }
		} else {
			visibleColumns = defaultColumns;
		}

		// Update checkboxes
		document.querySelectorAll('.column-checkbox').forEach(function(cb) {
			cb.checked = visibleColumns.indexOf(cb.getAttribute('data-column')) !== -1;
		});

		// Apply visibility
		applyColumnVisibility(visibleColumns);
	};

	window.saveColumnPreference = function(listName) {
		var selected = [];
		document.querySelectorAll('.column-checkbox:checked').forEach(function(cb) {
			var col = cb.getAttribute('data-column');
			if (col) selected.push(col);
		});
		if (selected.length === 0) {
			alert('{{.i18n.Tr "Select_At_Least_One_Column"}}');
			return;
		}
		localStorage.setItem(getStorageKey(listName), JSON.stringify(selected));
		applyColumnVisibility(selected);
		closePanel();
	};

	window.resetColumns = function(listName) {
		localStorage.removeItem(getStorageKey(listName));
		var el = document.getElementById('columnSelectorButton');
		var defaultJSON = el ? el.getAttribute('data-default') : null;
		initColumnSelector(listName, defaultJSON);
		closePanel();
	};

	function applyColumnVisibility(visibleColumns) {
		document.querySelectorAll('table th[data-column], table td[data-column]').forEach(function(el) {
			el.style.display = visibleColumns.indexOf(el.getAttribute('data-column')) !== -1 ? '' : 'none';
		});
	}

	// Auto-init on page load
	document.addEventListener('DOMContentLoaded', function() {
		var el = document.getElementById('columnSelectorButton');
		if (el) {
			var listName = el.getAttribute('data-listname');
			var defaultJSON = el.getAttribute('data-default');
			if (listName) initColumnSelector(listName, defaultJSON);
		}
	});
})();
</script>

<style>
.column-selector-wrapper {
	display: inline-block;
	position: relative;
	margin-right: 0.5em;
	vertical-align: middle;
}
.column-selector-panel {
	display: none;
	position: absolute;
	right: 0;
	top: 100%;
	z-index: 1000;
	background: #fff;
	border: 1px solid rgba(34,36,38,.15);
	border-radius: 4px;
	box-shadow: 0 2px 8px rgba(0,0,0,.15);
	min-width: 180px;
	padding: 8px 0;
	margin-top: 4px;
}
.column-selector-panel.visible {
	display: block;
}
.column-selector-list {
	max-height: 300px;
	overflow-y: auto;
	padding: 0 12px;
}
.column-selector-item {
	display: flex;
	align-items: center;
	gap: 6px;
	padding: 4px 0;
	cursor: pointer;
	font-size: 13px;
	white-space: nowrap;
}
.column-selector-item:hover {
	color: #2185d0;
}
.column-selector-item input[type="checkbox"] {
	margin: 0;
}
.column-selector-actions {
	border-top: 1px solid rgba(34,36,38,.1);
	padding: 8px 12px 4px;
	margin-top: 4px;
	display: flex;
	gap: 6px;
}
.column-selector-actions .ui.button {
	margin: 0 !important;
}
</style>
{{end}}
