{{template "_head" .}}
    <div class="admin user">
        <div class="ui container">
            <div class="ui grid">
                {{template "_left" .}}
                <div class="twelve wide column content">
                    <h4 class="ui top attached header">
                        {{.i18n.Tr "IP_Whitelist_Manage_Panel"}} ({{.i18n.Tr "Total"}}: {{.Total}})
                        <div class="ui right">
                            {{template "_column_selector" .}}
                            <a class="ui green tiny button" href="ip-whitelists/new">{{.i18n.Tr "Create"}}</a>
                            <button class="ui blue tiny button" id="refresh-whitelist-btn" onclick="refreshWhitelist(event)">{{.i18n.Tr "Refresh"}}</button>
                        </div>
                    </h4>
                    <div class="ui attached segment">
                        <form class="ui form">
                            <div class="ui fluid tiny action input">
                                <input name="q" value="{{ .Query }}" placeholder="Search IP or Instance UUID..." autofocus>
                                <button class="ui blue tiny button">{{.i18n.Tr "Search"}}</button>
                            </div>
                        </form>
                    </div>
                    <div class="ui unstackable attached table segment">
                        <table class="ui unstackable very basic striped table">
                            <thead>
                                <tr>
                                    {{ if $.IsAdmin }}
                                    <th data-column="ID">{{.i18n.Tr "ID"}}</th>
                                    {{ end }}
                                    <th data-column="UUID">{{.i18n.Tr "UUID"}}</th>
                                    <th data-column="InstanceUUID">{{.i18n.Tr "InstanceUUID"}}</th>
                                    <th data-column="IP">{{.i18n.Tr "IP"}}</th>
                                    <th data-column="Reason">{{.i18n.Tr "Reason"}}</th>
                                    {{ if $.IsAdmin }}
                                    <th data-column="Owner">{{.i18n.Tr "Owner"}}</th>
                                    {{ end }}
                                    <th data-column="CreatedAt">{{.i18n.Tr "CreatedAt"}}</th>
                                    <th data-column="Delete">{{.i18n.Tr "Delete"}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{ $Link := .Link }}
                                {{ range .IPWhitelists }}
                                <tr>
                                    {{ if $.IsAdmin }}
                                    <td data-column="ID">{{.ID}}</td>
                                    {{ end }}
                                    <td data-column="UUID">{{.UUID}}</td>
                                    <td data-column="InstanceUUID">{{.InstanceUUID}}</td>
                                    <td data-column="IP">{{.IP}}</td>
                                    <td data-column="Reason">{{.Reason}}</td>
                                    {{ if $.IsAdmin }}
                                    <td data-column="Owner">{{ if .OwnerInfo }}{{.OwnerInfo.Name}}{{ end }}</td>
                                    {{ end }}
                                    <td data-column="CreatedAt">{{.CreatedAt}}</td>
                                    <td data-column="Delete"><div class="delete-button" data-url="{{$Link}}/{{.UUID}}" data-id="{{.UUID}}"><i class="dark purple trash alternate outline icon"></i></div></td>
                                </tr>
                                {{ end }}
                            </tbody>
                        </table>
                    </div>
                    {{template "_pagination" .}}
                </div>
            </div>
        </div>
    </div>
    <div class="ui small basic delete modal">
        <div class="ui icon header">
            <i class="trash icon"></i>
            {{.i18n.Tr "IPWhitelist Deletion"}}
        </div>
        <div class="content">
            <p>{{.i18n.Tr "IPWhitelist_Deletion_Confirm"}}</p>
        </div>
        {{template "_delete_modal_actions" .}}
    </div>
<script>
function refreshWhitelist(e) {
    e.preventDefault();
    var btn = document.getElementById('refresh-whitelist-btn');
    btn.classList.add('loading', 'disabled');
    fetch('ip-whitelists/refresh', {method: 'POST', credentials: 'same-origin'}).then(function(r) {
        return r.json();
    }).then(function(data) {
        btn.classList.remove('loading', 'disabled');
        if (data.error) {
            alert('Refresh failed: ' + data.error);
        } else {
            alert('Refresh sent to all compute nodes');
        }
    }).catch(function(err) {
        btn.classList.remove('loading', 'disabled');
        alert('Refresh failed: ' + err);
    });
}
</script>
{{template "_footer" .}}
